<Window
    x:Class="SpaceInvaders.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SpaceInvaders"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="500"
    FocusManager.FocusedElement="{Binding ElementName=myCanvas}"
    mc:Ignorable="d">
    <Canvas
        Name="myCanvas"
        Background="Black"
        Focusable="True"
        KeyDown="CanvasKeyIsDown"
        KeyUp="CanvasKeyIsUp">
        <Label
            Name="enemiesLeft"
            FontSize="16"
            FontWeight="ExtraBold"
            Foreground="White">
            Enemies Left :
        </Label>
        <Rectangle
            Name="player1"
            Canvas.Left="370"
            Canvas.Top="394"
            Width="55"
            Height="65"
            Fill="White" />
    </Canvas>
</Window>
